<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/hud_screen_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg_blue"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tv_username_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:text="INVENTORY // RSI"
                android:textColor="@color/sc_accent"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:letterSpacing="0.1"
                android:text="库存查看"
                android:textColor="@color/sc_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="登录后查看你的账号库存"
                android:textColor="@color/sc_text_mid"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Login panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:text="用户名"
                android:textColor="@color/sc_text_dim"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/et_username"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_bg"
                android:hint="账号"
                android:inputType="text"
                android:paddingHorizontal="10dp"
                android:textColor="@color/sc_text"
                android:textColorHint="@color/sc_text_dim"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_password_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:text="密码"
                android:textColor="@color/sc_text_dim"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_bg"
                android:hint="密码"
                android:inputType="textPassword"
                android:paddingHorizontal="10dp"
                android:textColor="@color/sc_text"
                android:textColorHint="@color/sc_text_dim"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/container_account_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_profile_avatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/avatar_placeholder"
                    android:contentDescription="角色头像"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Bug.Circle"
                    app:strokeColor="@color/sc_accent_dim"
                    app:strokeWidth="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_profile_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="已登录"
                        android:textColor="@color/sc_text"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_profile_handle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="monospace"
                        android:textColor="@color/sc_text_mid"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_captcha_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:text="图片验证码"
                android:textColor="@color/sc_text_dim"
                android:textSize="12sp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/iv_captcha"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="4dp"
                android:adjustViewBounds="true"
                android:background="@drawable/input_bg"
                android:contentDescription="RSI 图片验证码"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:visibility="gone" />

            <EditText
                android:id="@+id/et_captcha"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_bg"
                android:hint="输入图片中的验证码"
                android:inputType="textCapCharacters|textNoSuggestions"
                android:paddingHorizontal="10dp"
                android:textColor="@color/sc_text"
                android:textColorHint="@color/sc_text_dim"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_code_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:text="二步验证码"
                android:textColor="@color/sc_text_dim"
                android:textSize="12sp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/et_code"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_bg"
                android:hint="邮箱验证码，可包含英文字母"
                android:inputType="textCapCharacters|textNoSuggestions"
                android:paddingHorizontal="10dp"
                android:textColor="@color/sc_text"
                android:textColorHint="@color/sc_text_dim"
                android:textSize="14sp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_login"
                    style="?android:attr/buttonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="2"
                    android:background="@drawable/button_inventory_primary"
                    android:letterSpacing="0.08"
                    android:text="登录并拉取库存"
                    android:textColor="@color/sc_ink"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_logout"
                    style="?android:attr/buttonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/button_inventory_secondary"
                    android:text="退出登录"
                    android:textColor="@color/sc_text_mid"
                    android:textSize="14sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_refresh"
                style="?android:attr/buttonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/button_inventory_success"
                android:letterSpacing="0.08"
                android:text="刷新库存"
                android:textColor="@color/sc_ink"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="请先登录 RSI 账号，再查看库存"
                android:textColor="@color/sc_text_mid"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_last_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:textColor="@color/sc_text_dim"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_debug"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@color/sc_panel2"
                android:fontFamily="monospace"
                android:padding="6dp"
                android:textColor="@color/sc_warn"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/sc_danger"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Inventory list -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.08"
                    android:text="库存清单 · MANIFEST"
                    android:textColor="@color/sc_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_item_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="0 项"
                    android:textColor="@color/sc_text_mid"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_empty_inventory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="暂无库存数据"
                android:textColor="@color/sc_text_dim"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/container_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical" />

            <LinearLayout
                android:id="@+id/container_pagination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <Button
                    android:id="@+id/btn_prev_page"
                    style="?android:attr/buttonStyle"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/sc_panel2"
                    android:text="上一页"
                    android:textColor="@color/sc_text_mid"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_page_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="1 / 1"
                    android:textColor="@color/sc_text_mid"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btn_next_page"
                    style="?android:attr/buttonStyle"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/sc_panel2"
                    android:text="下一页"
                    android:textColor="@color/sc_text_mid"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
