<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/hud_screen_bg"
    android:orientation="vertical">

    <!-- Sticky header + search -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/sc_bg"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:letterSpacing="0.1"
                android:text="蓝图图鉴"
                android:textColor="@color/sc_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_data_ver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="—"
                android:textColor="@color/sc_text_dim"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Search row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/input_bg"
                android:hint="搜索蓝图 / 材料（如 愈金 / Riccite）…"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingHorizontal="12dp"
                android:textColor="@color/sc_text"
                android:textColorHint="@color/sc_text_dim"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_search"
                style="?android:attr/buttonStyle"
                android:layout_width="72dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/sc_accent"
                android:text="搜索"
                android:textColor="@color/sc_ink"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Category filter chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/container_category_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>
    </LinearLayout>

    <!-- List + loading -->
    <ScrollView
        android:id="@+id/scroll_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp">

            <!-- Loading state -->
            <TextView
                android:id="@+id/tv_loading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="加载中…"
                android:textColor="@color/sc_text_dim"
                android:textSize="14sp" />

            <!-- Empty state -->
            <TextView
                android:id="@+id/tv_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/card_bg"
                android:gravity="center"
                android:padding="16dp"
                android:text="未找到匹配的蓝图"
                android:textColor="@color/sc_text_mid"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Blueprint cards -->
            <LinearLayout
                android:id="@+id/container_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

            <!-- Show more -->
            <Button
                android:id="@+id/btn_more"
                style="?android:attr/buttonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/sc_panel2"
                android:text="加载更多"
                android:textColor="@color/sc_text_mid"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
