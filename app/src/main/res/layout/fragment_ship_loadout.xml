<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/hud_screen_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="配装改装 // BETA"
            android:textColor="@color/sc_accent"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_ship_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:textColor="@color/sc_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="1) 先选改装分类（武器/护盾/电源等）"
            android:textColor="@color/sc_text_mid"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/sp_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tv_step_slot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="2) 选择该分类下的槽位"
            android:textColor="@color/sc_text_mid"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/sp_slot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="3) 选择可装组件（同类型同尺寸）"
            android:textColor="@color/sc_text_mid"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/sp_component"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btn_add_slot"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="加入当前槽位配置" />
            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />
            <Button
                android:id="@+id/btn_reset_default"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="恢复默认模板" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/panel_power"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="电量分配面板（测试）"
                android:textColor="@color/sc_accent"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_power_head"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="输出 0.0 · 已用 0.0 · 剩余 0 / 30 格"
                android:textColor="@color/sc_text"
                android:textSize="13sp" />

            <ProgressBar
                android:id="@+id/pb_power_ratio"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="6dp"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/tv_power_ratio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="总耗电 0%"
                android:textColor="@color/sc_text_mid"
                android:textSize="12sp" />

            <com.euedrc.bugsc.shipfit.PowerDistributionView
                android:id="@+id/power_grid"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tv_power_groups"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="武器 0 | 护盾 0 | 量子 0 | 雷达 0 | 冷却 0"
                android:textColor="@color/sc_text_mid"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_slot_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:text="当前配置：暂无组件"
            android:textColor="@color/sc_text_mid"
            android:textSize="12sp" />

        <!-- 内部状态载体：存 port=组件id，供加组件/生成码/解码/电量计算读写。
             内容是内部 id 用户看不懂，故隐藏；逻辑仍照常读写此控件。 -->
        <EditText
            android:id="@+id/et_slots"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/input_bg"
            android:gravity="top|start"
            android:hint="当前配船配置（高级模式可手改）"
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:textColor="@color/sc_text"
            android:textColorHint="@color/sc_text_dim"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_generate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="生成配船码" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btn_decode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="解析配船码" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_code"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/input_bg"
            android:gravity="top|start"
            android:hint="BUGFIT:v1:..."
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:textColor="@color/sc_text"
            android:textColorHint="@color/sc_text_dim" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_copy_code"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="复制" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btn_paste_code"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="粘贴" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/sc_text_mid"
            android:textSize="13sp" />
    </LinearLayout>

</ScrollView>
