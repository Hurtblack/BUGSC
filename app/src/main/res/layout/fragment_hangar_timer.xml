<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/hud_screen_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Status banner -->
        <LinearLayout
            android:id="@+id/status_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#556574"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:text="HANGAR // STATUS"
                android:textColor="#E8FFFFFF"
                android:textSize="11sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_hangar_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.1"
                android:text="初始化中"
                android:textColor="#ffffff"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Countdown card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_phase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:text="T-MINUS // NEXT TRANSITION"
                android:textColor="@color/sc_accent"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:text="00:00:00"
                android:textColor="@color/sc_text"
                android:textSize="40sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/countdown_digits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/digit_0"
                    android:layout_width="34dp"
                    android:layout_height="54dp"
                    android:background="@drawable/digit_box_bg"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="@color/sc_accent"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/digit_1"
                    android:layout_width="34dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/digit_box_bg"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="@color/sc_accent"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="16dp"
                    android:layout_height="54dp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text=":"
                    android:textColor="@color/sc_text_mid"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/digit_2"
                    android:layout_width="34dp"
                    android:layout_height="54dp"
                    android:background="@drawable/digit_box_bg"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="@color/sc_accent"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/digit_3"
                    android:layout_width="34dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/digit_box_bg"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="@color/sc_accent"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="16dp"
                    android:layout_height="54dp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text=":"
                    android:textColor="@color/sc_text_mid"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/digit_4"
                    android:layout_width="34dp"
                    android:layout_height="54dp"
                    android:background="@drawable/digit_box_bg"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="@color/sc_accent"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/digit_5"
                    android:layout_width="34dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/digit_box_bg"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="@color/sc_accent"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_helper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/sc_text_mid"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Lights card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:id="@+id/lights_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/light_0"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1" />

                <FrameLayout
                    android:id="@+id/light_1"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1" />

                <FrameLayout
                    android:id="@+id/light_2"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1" />

                <FrameLayout
                    android:id="@+id/light_3"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1" />

                <FrameLayout
                    android:id="@+id/light_4"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_tip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="自动倒计时与自动变灯进行中"
                android:textColor="@color/sc_text_mid"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Actions card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp">

            <Button
                android:id="@+id/btn_main"
                style="?android:attr/buttonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/sc_accent"
                android:letterSpacing="0.1"
                android:text="添加闹钟"
                android:textColor="@color/sc_ink"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btn_sync"
                style="?android:attr/buttonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/sc_ok"
                android:letterSpacing="0.1"
                android:text="同步时间"
                android:textColor="@color/sc_ink"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_sync_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/sc_ok"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Calibration card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="校准码 · CAL"
                android:textColor="@color/sc_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="分享会生成 CAL 码；粘贴后可按同一锚点快速对齐"
                android:textColor="@color/sc_text_mid"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_share_cal"
                style="?android:attr/buttonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/sc_accent"
                android:letterSpacing="0.1"
                android:text="生成并复制校准码"
                android:textColor="@color/sc_ink"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_calibration_input"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_bg"
                android:fontFamily="monospace"
                android:gravity="top"
                android:hint="粘贴 CAL| 开头的校准码"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="@color/sc_accent"
                android:textColorHint="@color/sc_text_dim"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_apply_cal"
                style="?android:attr/buttonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:backgroundTint="@color/sc_warn"
                android:letterSpacing="0.1"
                android:text="粘贴并校准"
                android:textColor="@color/sc_ink"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
