<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- selected -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/sc_accent_ink" />
            <corners android:radius="14dp" />
            <stroke android:color="@color/sc_accent" android:width="1dp" />
        </shape>
    </item>
    <!-- default -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/sc_panel" />
            <corners android:radius="14dp" />
            <stroke android:color="@color/sc_line" android:width="1dp" />
        </shape>
    </item>
</selector>
