<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- panel body + faint hairline border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/sc_panel" />
            <corners android:radius="2dp" />
            <stroke android:width="1dp" android:color="@color/sc_line" />
        </shape>
    </item>

    <!-- top-left bracket -->
    <item android:gravity="top|left" android:width="16dp" android:height="2dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>
    <item android:gravity="top|left" android:width="2dp" android:height="16dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>

    <!-- top-right bracket -->
    <item android:gravity="top|right" android:width="16dp" android:height="2dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>
    <item android:gravity="top|right" android:width="2dp" android:height="16dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>

    <!-- bottom-left bracket -->
    <item android:gravity="bottom|left" android:width="16dp" android:height="2dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>
    <item android:gravity="bottom|left" android:width="2dp" android:height="16dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>

    <!-- bottom-right bracket -->
    <item android:gravity="bottom|right" android:width="16dp" android:height="2dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>
    <item android:gravity="bottom|right" android:width="2dp" android:height="16dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>
</layer-list>
