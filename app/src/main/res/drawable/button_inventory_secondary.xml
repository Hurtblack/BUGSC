<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/sc_ripple_light">

    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="@android:color/white" />
        </shape>
    </item>

    <item>
        <selector>
            <item android:state_pressed="true">
                <shape android:shape="rectangle">
                    <corners android:radius="10dp" />
                    <solid android:color="@color/sc_panel2_pressed" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/sc_line2" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="10dp" />
                    <solid android:color="@color/sc_panel2" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/sc_line" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>
