<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#1A21D4FF"
                android:endColor="@color/sc_panel2"
                android:type="linear" />
            <corners android:radius="2dp" />
            <stroke android:width="1dp" android:color="@color/sc_accent" />
        </shape>
    </item>

    <item android:gravity="top|left" android:width="18dp" android:height="2dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>
    <item android:gravity="top|left" android:width="2dp" android:height="18dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>
    <item android:gravity="top|right" android:width="18dp" android:height="2dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>
    <item android:gravity="top|right" android:width="2dp" android:height="18dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>
    <item android:gravity="bottom|left" android:width="18dp" android:height="2dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>
    <item android:gravity="bottom|left" android:width="2dp" android:height="18dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>
    <item android:gravity="bottom|right" android:width="18dp" android:height="2dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>
    <item android:gravity="bottom|right" android:width="2dp" android:height="18dp">
        <shape android:shape="rectangle"><solid android:color="@color/sc_accent" /></shape>
    </item>
</layer-list>
